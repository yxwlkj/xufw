{
  "version": 2,
  "builds": [
    {
      "src": "playground/nuxt.config.ts",
      "use": "@nuxtjs/vercel-builder",
      "config": {
        "rootDir": "playground"
      }
    }
  ],
  "buildCommand": "pnpm nuxt build playground",
  "outputDirectory": "playground/.output/public",
  "installCommand": "pnpm install",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/playground/.output/public/$1"
    }
  ]
}
